  "description": "Proxy to Ollama hosted models and inference server.",
  "main": "app.js",
  "author": "Davy Braun",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "nodemon ./dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
